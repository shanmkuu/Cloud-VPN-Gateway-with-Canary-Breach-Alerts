# =============================================================================
# .env.example — WireGuard Canary Monitor Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp configs/.env.example /opt/wg-canary/.env
#   chmod 600 /opt/wg-canary/.env
# =============================================================================

# ── Webhook Configuration (REQUIRED) ─────────────────────────────────────────
# Your Discord or Slack webhook URL
# Discord: Server Settings → Integrations → Webhooks → Copy Webhook URL
# Slack  : api.slack.com/messaging/webhooks
WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Webhook type: "discord" | "slack"
WEBHOOK_TYPE=discord

# ── Log Monitoring ────────────────────────────────────────────────────────────
# Full path to the syslog file containing WireGuard kernel messages
# Ubuntu/Debian: /var/log/syslog
# RHEL/CentOS  : /var/log/messages  (or use journald export)
LOG_PATH=/var/log/syslog

# ── Alert Thresholds ──────────────────────────────────────────────────────────
# Number of authentication failures from a single IP before alerting
ALERT_THRESHOLD=5

# Sliding window duration in seconds (120 = 2 minutes)
ALERT_WINDOW_SECS=120

# ── GeoIP Enrichment ──────────────────────────────────────────────────────────
# ip-api.com is free for non-commercial use (< 45 req/min)
# For production: consider ipinfo.io (IPINFO_TOKEN required) or MaxMind GeoLite2
GEOIP_API_URL=http://ip-api.com/json

# ── Development / Testing ─────────────────────────────────────────────────────
# Set to "1" to print webhook payloads to stdout without sending them
DRY_RUN=0
